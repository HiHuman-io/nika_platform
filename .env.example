# Copy to `.env` on the VPS (next to docker-compose.yml) and fill in real values.
# docker-compose reads this file for build args + runtime env.

# Public — inlined into the client bundle AND read by the server client.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Server-only — the manual-import webhook (production URL, workflow must be Active).
N8N_IMPORT_WEBHOOK_URL=https://n8n.hihuman.io/webhook/nika-import
