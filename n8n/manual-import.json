      "id": "717915a9-a734-474a-8e89-acd6db7122d2",
      "name": "Mark Done",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        2000,
        1080
      ],
      "credentials": {
        "supabaseApi": {
          "id": "kkiHzEYLOtK6ZLEy",
          "name": "Nika"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Explode each relevant AI result into one row per catalog item.\nconst rows = [];\nconst inputs = $input.all();\nfor (let i = 0; i < inputs.length; i++) {\n  let result = inputs[i].json;\n  result = result.message?.content ?? result.content ?? result;\n  if (typeof result === 'string') { try { result = JSON.parse(result); } catch (e) { continue; } }\n  if (!result || result.is_catalog_relevant === false) continue;\n\n  let src = {};\n  try { src = $('Set Fields').itemMatching(i).json; } catch (e) {}\n\n  for (const item of (result.items ?? [])) {\n    rows.push({ json: {\n      action: item.action === 'update' ? 'update' : 'create',\n      match_line_id: item.match_line_id ?? null,\n      match_confidence: item.match_confidence ?? null,\n      status: 'in_progress',\n      label: result.label ?? null,\n      overall_confidence: result.overall_confidence ?? null,\n      needs_review: result.needs_review ?? null,\n      source_message_id: src.message_id ?? null,\n      artist_raw: item.artist_raw ?? null,\n      artist: item.artist ?? null,\n      title: item.title ?? null,\n      format: item.format ?? null,\n      ean: item.ean ?? null,\n      catalogue_no: item.catalogue_no ?? null,\n      release_date: item.release_date ?? null,\n      price_eur: item.price_eur ?? null,\n      calculation_group: item.calculation_group ?? null,\n      supplier_code: item.supplier_code ?? null,\n      custom_tariff: item.custom_tariff ?? null,\n      tax_rate: item.tax_rate ?? null,\n      unit_of_measure: item.unit_of_measure ?? null,\n      classification: item.classification ?? null,\n      excluded: item.excluded ?? false,\n      exclusion_reason: item.exclusion_reason ?? null,\n      missing_mandatory: item.missing_mandatory ?? [],\n      item_confidence: item.item_confidence ?? null,\n      item_notes: item.item_notes ?? null,\n    } });\n  }\n}\nreturn rows;"
      },
